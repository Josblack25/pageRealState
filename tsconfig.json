{
  "extends": "astro/tsconfigs/strict",
  "include": [
    "src/**/*",
    ".astro/types.d.ts"
  ],
  "exclude": ["dist", "node_modules"],
  
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  }
} 